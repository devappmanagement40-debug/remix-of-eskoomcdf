# ===============================================================
# GE Energy — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
# Sur Plesk : configurez ces vars dans Node.js > Environnement
# ===============================================================

# --- Base de données (OBLIGATOIRE) ---
# Format PostgreSQL : postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@localhost:5432/geenergy

# --- Serveur ---
NODE_ENV=production
PORT=3000

# --- Supabase (optionnel — si vous utilisez Supabase comme DB principale) ---
# VITE_SUPABASE_PROJECT_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- IA (optionnel — pour le chatbot Sarah) ---
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Paiements Crypto (optionnel) ---
# NOWPAYMENTS_API_KEY=...

# --- Dossier uploads (optionnel — défaut : ./public/uploads) ---
# UPLOAD_DIR=/var/www/geenergy/public/uploads
